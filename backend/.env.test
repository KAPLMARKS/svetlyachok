# Тестовое окружение для pytest. Подгружается через pydantic-settings,
# когда тесты переопределяют переменные через monkeypatch.setenv или
# через явное указание env_file в Settings.
# НЕ использовать в production.

ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# Фиктивный DSN — БД не поднимается в smoke-тестах.
DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/test

# JWT secret >= 32 символов (требование валидатора Settings)
JWT_SECRET=test_secret_at_least_32_chars_long_for_pytest
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=[]
