# Скопируйте этот файл в .env и заполните реальными значениями.
# В production .env НЕ должен попадать в git (см. .gitignore).

# --- Application ---
APP_NAME=svetlyachok-backend
ENVIRONMENT=development

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# --- Database ---
# Используем asyncpg-драйвер для async SQLAlchemy.
# Для production задайте надёжный пароль и ограничьте доступ по network.
DATABASE_URL=postgresql+asyncpg://svetlyachok:dev_password@localhost:5432/svetlyachok

# --- JWT / Security ---
# Сгенерировать надёжный секрет: openssl rand -base64 48
# Минимум 32 символа. НЕ коммитить настоящие секреты.
JWT_SECRET=PLACEHOLDER_change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Разделять origin запятыми. Пустой = CORS отключён (только same-origin).
# Пример для dev: CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS=[]

# --- Rate limiting (защита /auth-эндпоинтов от брутфорса) ---
# Формат slowapi: "<count>/<period>", где period — second/minute/hour/day.
# Снижать значения только в exceptional cases (например, для CI-тестов).
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_REFRESH_RATE_LIMIT=10/minute
AUTH_LOGOUT_RATE_LIMIT=10/minute
